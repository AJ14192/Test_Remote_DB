{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "moduleResolution": "node",

    /* Strictness */
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    /* Node + Playwright Support */
    "types": ["node", "@playwright/test"],

    /* Interop */
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* Build Output */
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",

    /* Path Alias */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },

  "include": [
    "tests/**/*",
    "utils/**/*",
    "*.config.ts",
    "*.d.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}